---
---
<section id="achievements">
  <h2 class="fade-in">Competitions</h2>

  <div class="photos fade-in">
    <figure>
      <img src="/images/cyberforce-team.jpg" alt="DOE Cyberforce Competition" loading="lazy" />
      <figcaption>DOE Cyberforce - 11th / 96 nationally</figcaption>
    </figure>
    <figure>
      <img src="/images/tulane-cyber.jpg" alt="Tulane Cyber Challenge" loading="lazy" />
      <figcaption>Tulane Cyber Challenge - 1st place</figcaption>
    </figure>
  </div>

  <ul class="wins fade-in d1">
    <li><strong>1st Place</strong> - Tulane / Operation Spark Cyber Challenge, 2024, 2025</li>
    <li><strong>11th / 96 Teams Nationally</strong> - DOE Cyberforce Competition, Nov 2025</li>
    <li><strong>UPE Honor Society</strong> - CS International Honor Society</li>
    <li><strong>President's List</strong> - Southeastern Louisiana University, multiple semesters</li>
    <li><strong>Runner-Up</strong> - SLU Integration Bee, Math Department</li>
  </ul>
</section>

<style>
  .photos {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1.25rem; margin-bottom: 2rem;
  }
  .photos figure { margin: 0; overflow: hidden; border-radius: 3px; }
  .photos img {
    width: 100%; aspect-ratio: 16 / 10; object-fit: cover;
    border-radius: 3px; border: 1px solid var(--border);
    transition: transform 0.4s ease;
  }
  .photos figure:hover img { transform: scale(1.03); }
  .photos figcaption { font-size: 0.75rem; color: var(--light); margin-top: 0.5rem; }
  .wins { list-style: none; padding: 0; }
  .wins li {
    padding: 0.6rem 0; border-bottom: 1px solid var(--border);
    font-size: 0.9rem; color: var(--muted); line-height: 1.5;
  }
  .wins li:last-child { border-bottom: none; }
  .wins strong { color: var(--text); font-weight: 500; }
  @media (max-width: 640px) { .photos { grid-template-columns: 1fr; } }
</style>