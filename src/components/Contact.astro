---

<section id="contact">
  <div class="section-wrap">
    <div class="contact-inner">
      <div class="contact-left reveal">
        <h2>Let's build something <em>worth breaking.</em></h2>
        <p>
          I'm actively looking for Summer 2026 internship opportunities in
          security engineering, full-stack development, and software
          engineering. Reach out — I respond fast.
        </p>
        <div class="contact-links">
          <a
            href="https://github.com/Sudhakar-exe"
            target="_blank"
            class="contact-link"
          >
            <div class="contact-link-icon">☰</div>
            <div class="contact-link-text">
              <div class="contact-link-label">GitHub</div>
              <div class="contact-link-value">Sudhakar-exe</div>
            </div>
            <span class="contact-link-arrow">→</span>
          </a>
          <a
            href="https://linkedin.com/in/sudhakarchaulagain"
            target="_blank"
            class="contact-link"
          >
            <div class="contact-link-icon">in</div>
            <div class="contact-link-text">
              <div class="contact-link-label">LinkedIn</div>
              <div class="contact-link-value">/sudhakarchaulagain</div>
            </div>
            <span class="contact-link-arrow">→</span>
          </a>
          <a href="mailto:sudhakar.chaulagain@selu.edu" class="contact-link">
            <div class="contact-link-icon">@</div>
            <div class="contact-link-text">
              <div class="contact-link-label">Email</div>
              <div class="contact-link-value">sudhakar.chaulagain@selu.edu</div>
            </div>
            <span class="contact-link-arrow">→</span>
          </a>
        </div>
      </div>
      <div class="contact-right-terminal reveal reveal-delay-1">
        <div class="terminal-bar">
          <div class="terminal-dot red"></div>
          <div class="terminal-dot yel"></div>
          <div class="terminal-dot grn"></div>
          <span>sudhakar@portfolio ~ %</span>
        </div>
        <div class="terminal-body">
          <span class="cmd">$</span> cat status.json<br />
          {"{"}<br />
          &nbsp;&nbsp;<span class="val">"seeking"</span>: <span class="val"
            >"Summer 2026 Internship"</span
          >,<br />
          &nbsp;&nbsp;<span class="val">"roles"</span>: [<span class="val"
            >"Security Engineer"</span
          >, <span class="val">"Full-Stack Dev"</span>, <span class="val"
            >"SWE"</span
          >],<br />
          &nbsp;&nbsp;<span class="val">"clearance"</span>: <span class="val"
            >"Open to relocation"</span
          >,<br />
          &nbsp;&nbsp;<span class="val">"response_time"</span>: <span
            class="val">"&lt; 24 hours"</span
          ><br />
          {"}"}<br /><br />
          <span class="cmd">$</span> echo <span class="val">"Let's talk."</span
          ><br />
          Let's talk.<br />
          <span class="cmd">$ █</span>
        </div>
      </div>
    </div>
  </div>
</section>

<footer>
  &copy; 2026 Sudhakar Chaulagain · Built with purpose, not a template.
</footer>

<style>
  #contact {
    background: var(--surface);
  }
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .contact-left h2 {
    font-family: var(--serif);
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 600;
    color: var(--text);
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }
  .contact-left h2 em {
    font-style: italic;
    color: var(--amber);
  }
  .contact-left p {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    transition: all 0.25s;
  }
  .contact-link:hover {
    border-color: rgba(232, 160, 32, 0.35);
    transform: translateX(8px);
  }
  .contact-link-icon {
    font-family: var(--mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--amber);
    width: 2.5rem;
    text-align: center;
  }
  .contact-link-text {
    flex: 1;
  }
  .contact-link-label {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .contact-link-value {
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--text);
    margin-top: 0.15rem;
  }
  .contact-link-arrow {
    font-family: var(--mono);
    color: var(--muted);
    transition: color 0.2s;
  }
  .contact-link:hover .contact-link-arrow {
    color: var(--amber);
  }

  .contact-right-terminal {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(0, 0, 0, 0.25);
    border-bottom: 1px solid var(--border);
  }
  .terminal-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .terminal-dot.red {
    background: #ff5f57;
  }
  .terminal-dot.yel {
    background: #febc2e;
  }
  .terminal-dot.grn {
    background: #28c840;
  }
  .terminal-bar span {
    margin-left: 0.5rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--muted);
  }
  .terminal-body {
    padding: 1.5rem;
    font-family: var(--mono);
    font-size: 0.78rem;
    line-height: 2;
    color: var(--muted);
  }
  .terminal-body .cmd {
    color: var(--green);
  }
  .terminal-body .val {
    color: var(--amber);
  }

  footer {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 3rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--muted);
    border-top: 1px solid var(--border);
  }

  @media (max-width: 1024px) {
    .contact-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
