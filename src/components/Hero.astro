<section id="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Available for Summer 2026 Internships</div>
      <h1 class="hero-name">Sudhakar<br /><em>Chaulagain</em></h1>
      <div class="typed-wrap">
        <span id="typed-text"></span><span class="cursor"></span>
      </div>
      <p class="hero-desc">
        CS junior at Southeastern Louisiana University building security tools,
        embedded systems, and full-stack applications. I find vulnerabilities in
        code and close them before they ship.
      </p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">View Projects ↓</a>
        <a href="#contact" class="btn">Get In Touch →</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">3.86</div>
        <div class="stat-label">GPA</div>
      </div>
      <div class="stat">
        <div class="stat-num">1st</div>
        <div class="stat-label">Tulane Cyber Challenge</div>
      </div>
      <div class="stat">
        <div class="stat-num">11th</div>
        <div class="stat-label">National · DOE Cyberforce</div>
      </div>
    </div>
  </div>
</section>

<script>
  const roles = [
    "Security Engineer",
    "Full-Stack Developer",
    "SAST Tool Builder",
    "CTF Competitor",
    "Embedded Systems Builder",
  ];
  let ri = 0,
    ci = 0,
    deleting = false,
    wait = 0;
  const el = document.getElementById("typed-text");
  function type() {
    if (wait > 0) {
      wait--;
      setTimeout(type, 80);
      return;
    }
    const word = roles[ri];
    if (!deleting) {
      el!.textContent = word.slice(0, ++ci);
      if (ci === word.length) {
        deleting = true;
        wait = 25;
      }
      setTimeout(type, 90);
    } else {
      el!.textContent = word.slice(0, --ci);
      if (ci === 0) {
        deleting = false;
        ri = (ri + 1) % roles.length;
      }
      setTimeout(type, 45);
    }
  }
  setTimeout(type, 1200);
</script>

