<section id="experience">
  <h2 class="fade-in">Experience</h2>

  <div class="exp-list">
    <div class="exp fade-in">
      <div class="exp-header">
        <h3>Lab Support Technician</h3>
        <span class="exp-date">Mar 2026 - present</span>
      </div>
      <p class="exp-org">Dept. of Industrial & Engineering Technology, Southeastern Louisiana University</p>
      <p>Managed inventory of 50+ lab devices, operated 3D printers, and supported embedded systems projects across multiple labs.</p>
    </div>

    <div class="exp fade-in">
      <div class="exp-header">
        <h3>Mathematics Tutor</h3>
        <span class="exp-date">Aug 2024 - Feb 2026</span>
      </div>
      <p class="exp-org">Southeastern Louisiana University</p>
      <p>Provided academic support in calculus, algebra, and discrete mathematics to 1000+ students per semester.</p>
    </div>

    <div class="exp fade-in">
      <div class="exp-header">
        <h3>Robotics Tutor & R&D Assistant</h3>
        <span class="exp-date">Feb 2023 - Jun 2023</span>
      </div>
      <p class="exp-org">Robotics Association of Nepal, Kathmandu</p>
      <p>Supported engineers on automation and embedded systems R&D. Delivered Arduino and Raspberry Pi training to 1000+ students.</p>
    </div>
  </div>

  <h2 class="fade-in">Skills</h2>

  <div class="skills-grid fade-in">
    <div>
      <h4>Languages</h4>
      <p>Python, JavaScript, C#, Java, C/C++, Kotlin, TypeScript, SQL, Bash</p>
    </div>
    <div>
      <h4>Security</h4>
      <p>SAST, Wireshark, Nmap, vulnerability assessment, incident response, penetration testing, ICS/OT, CTF</p>
    </div>
    <div>
      <h4>Frameworks & Tools</h4>
      <p>FastAPI, Flask, .NET, React, Astro, REST APIs, OAuth/JWT, Git, Docker, Pytest, CI/CD, Linux CLI</p>
    </div>
    <div>
      <h4>Hardware</h4>
      <p>Raspberry Pi, Arduino, sensor integration, serial communication, 3D printing</p>
    </div>
  </div>
</section>

<style>
  .exp-list { margin-bottom: 3rem; }
  .exp {
    margin-bottom: 2rem; padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .exp:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .exp-header {
    display: flex; justify-content: space-between; align-items: baseline;
    gap: 1rem; margin-bottom: 0.2rem;
  }
  .exp-header h3 { font-family: var(--serif); font-size: 1.05rem; font-weight: 600; }
  .exp-date { font-family: var(--mono); font-size: 0.75rem; color: var(--light); white-space: nowrap; }
  .exp-org { font-size: 0.82rem; color: var(--light); margin-bottom: 0.5rem; }
  .exp p:not(.exp-org) { color: var(--muted); line-height: 1.7; }
  .skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .skills-grid h4 {
    font-family: var(--mono); font-size: 0.75rem; font-weight: 500;
    color: var(--text); text-transform: uppercase; letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }
  .skills-grid p { font-size: 0.85rem; color: var(--muted); line-height: 1.65; }
  @media (max-width: 640px) {
    .exp-header { flex-direction: column; gap: 0.15rem; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>